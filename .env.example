# Copy this file to .env and fill in real values before running docker compose.
# Docker Compose reads this file for both variable substitution and container
# environment. For running an app directly on the host, use the .env.example
# inside backend/ and frontend/ instead.

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=communityhub

# Backend runtime
NODE_ENV=development
PORT=3000
JWT_SECRET=change_me_with_a_long_random_string
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
FRONTEND_URL=http://localhost:3001

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# pgAdmin (only started with the "tools" profile)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Frontend (exposed to the browser, so it must point to the host URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
