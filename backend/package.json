{
  "name": "communityhub-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:build": "docker build -t communityhub-backend .",
    "docker:build:prod": "docker build -t communityhub-backend:prod --target production .",
    "docker:dev": "docker-compose up --build",
    "docker:dev:detached": "docker-compose up -d --build",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d --build",
    "docker:stop": "docker-compose down",
    "docker:stop:prod": "docker-compose -f docker-compose.prod.yml down",
    "docker:logs": "docker-compose logs -f app",
    "docker:shell": "docker-compose exec app sh",
    "docker:db": "docker-compose exec postgres psql -U postgres -d communityhub",
    "docker:clean": "docker system prune -a --volumes",
    "typeorm": "ts-node --project tsconfig-typeorm.json -r tsconfig-paths/register",
    "migration:generate": "npm run typeorm -- ./node_modules/typeorm/cli.js migration:generate -d database/data-source.ts",
    "migration:create": "npm run typeorm -- ./node_modules/typeorm/cli.js migration:create",
    "migration:run": "npm run typeorm -- ./node_modules/typeorm/cli.js migration:run -d database/data-source.ts",
    "migration:revert": "npm run typeorm -- ./node_modules/typeorm/cli.js migration:revert -d database/data-source.ts",
    "migration:show": "npm run typeorm -- ./node_modules/typeorm/cli.js migration:show -d database/data-source.ts",
    "migration:drop": "npm run typeorm -- ./node_modules/typeorm/cli.js schema:drop -d database/data-source.ts",
    "migration:generate:local": "DB_HOST=localhost npm run migration:generate",
    "migration:run:local": "DB_HOST=localhost npm run migration:run",
    "migration:revert:local": "DB_HOST=localhost npm run migration:revert",
    "migration:show:local": "DB_HOST=localhost npm run migration:show"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.27",
    "@scalar/nestjs-api-reference": "^1.2.8",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-http-bearer": "^1.0.42",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.8.2",
    "nestjs-cls": "^6.0.1",
    "nodemailer": "^7.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.27",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.5.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bull": "^4.10.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.3",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.7.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
