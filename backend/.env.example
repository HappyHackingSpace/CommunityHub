# Database Configuration
# For Docker Compose: use service name (e.g., 'postgres')
# For local: use 'localhost'
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_database_username
DB_PASSWORD=your_secure_database_password
DB_DATABASE=communityhub

# Application Configuration
NODE_ENV=development
PORT=3000

# JWT Configuration
# Generate a new secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your_jwt_secret_here

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Redis Configuration
# Leave REDIS_PASSWORD empty for no authentication (development only)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PgAdmin Configuration (Local Development Only)
PGADMIN_DEFAULT_EMAIL=your_email@example.com
PGADMIN_DEFAULT_PASSWORD=your_secure_pgadmin_password
